<!DOCTYPE html>
html(lang="en")
    head
        include partials/header
    body
        header.barra
            h1 Control de Inventario Pro
            a(href="/cerrar-sesion") Cerrar Sesión

        main.contenedor
            aside.contenedor-proyectos
                .panel.crear-proyecto
                    a(href="/nuevo-proyecto" class="boton") Agregar Nuevo Registro
                        span +
                
                .panel
                    h2 Principal
                    ul.proyectos
                        li
                            a(href="/") 
                                i.fas.fa-chart-line
                                |  Vista General
                        li
                            a(href="#") 
                                i.fas.fa-file-invoice
                                |  Reportes de Stock
                
                .panel.lista-proyectos
                    h2 Categorías de Almacén
                    ul#proyectos.proyectos
                        if(proyectos.length)
                            each proyecto in proyectos
                                li
                                    a(href=`/proyectos/${proyecto.url}`)
                                        i.fas.fa-layer-group
                                        |  #{proyecto.nombre}
                
                .panel
                    h2 Herramientas
                    ul.proyectos
                        li
                            a(href="#") 
                                i.fas.fa-bell
                                |  Alertas de Stock
                        li
                            a(href="#") 
                                i.fas.fa-cog
                                |  Configuración
            block contenido

            //- pre= vardump(proyectos)
        
        script(src="/dist/bundle.js")
        